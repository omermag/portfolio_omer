import os
from apify_client import ApifyClient
from dotenv import load_dotenv

def fetch_google_maps_leads(category: str, location: str, limit: int, country_code: str = "il", language: str = "iw"):
    """
    Legacy function - calls fetch_leads_batch with single category.
    DEPRECATED: Use fetch_leads_batch for better performance.
    """
    return fetch_leads_batch([category], location, limit, country_code, language)


def fetch_leads_batch(search_terms: list, location: str, max_places_per_term: int, country_code: str = "il", language: str = "iw"):
    """
    Fetches leads from Google Maps using Apify's compass/crawler-google-places.
    
    Args:
        search_terms: List of search terms (categories only, e.g., ["Pizza", "Burger"])
        location: Location query (e.g., "Tel Aviv-Yafo, Israel")
        max_places_per_term: Maximum places to fetch per search term
        country_code: Country code for search (default: "il")
        language: Language code (default: "iw" for Hebrew)
    
    Returns:
        List of place results from Apify
    """
    load_dotenv()  # Load inside function to prevent blocking during import
    token = os.getenv("APIFY_API_TOKEN")
    if not token:
        raise ValueError("APIFY_API_TOKEN not found in .env")

    client = ApifyClient(token)

    run_input = {
        "searchStringsArray": search_terms,  # Categories only, no location
        "locationQuery": location,            # City/location - this is the search focus
        "maxCrawledPlacesPerSearch": max_places_per_term,
        "language": language,
        "countryCode": country_code,          # Keep Israel as country context
        "searchMatching": "all",
        "placeMinimumStars": "",
        "website": "allPlaces",
        "skipClosedPlaces": True,
        "scrapePlaceDetailPage": False,
        "scrapeTableReservationProvider": False,
        "includeWebResults": False,
        "scrapeDirectories": False,
        "maxQuestions": 0,
        "scrapeContacts": False,
        "scrapeSocialMediaProfiles": {
            "facebooks": False,
            "instagrams": False,
            "youtubes": False,
            "tiktoks": False,
            "twitters": False
        },
        "maximumLeadsEnrichmentRecords": 0,
        "maxReviews": 0,
        "reviewsSort": "newest",
        "reviewsFilterString": "",
        "reviewsOrigin": "all",
        "scrapeReviewsPersonalData": True,
        "maxImages": 0,
        "scrapeImageAuthors": False,
        "allPlacesNoSearchAction": ""
    }

    print(f"[Apify] Starting batch run for location: {location}", flush=True)
    print(f"[Apify] Search terms: {search_terms}", flush=True)
    print(f"[Apify] Max places per term: {max_places_per_term}", flush=True)
    
    try:
        run = client.actor("compass/crawler-google-places").call(run_input=run_input)
        dataset = client.dataset(run["defaultDatasetId"])
        items = dataset.list_items().items
        
        print(f"[Apify] Fetched {len(items)} total results", flush=True)
        return items
    except Exception as e:
        print(f"[Apify] ERROR: {e}", flush=True)
        return []

if __name__ == "__main__":
    results = fetch_google_maps_leads("אינסטלטור", "Tel Aviv", 2)
    for res in results:
        print(f"  - {res.get('title')} | {res.get('website')}")
