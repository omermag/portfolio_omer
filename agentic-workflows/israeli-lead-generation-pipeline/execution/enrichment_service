def extract_social_links(html: str) -> Dict[str, Optional[str]]:
    """Extract social media links from HTML."""
    socials = {
        "instagram": None,
        "facebook": None,
        "linkedin": None,
        "x": None
    }
    
    try:
        soup = BeautifulSoup(html, 'html.parser')
        
        for a_tag in soup.find_all('a', href=True):
            href = a_tag['href'].lower()
            
            if 'instagram.com' in href and not socials['instagram']:
                socials['instagram'] = href
            elif 'facebook.com' in href and not socials['facebook']:
                socials['facebook'] = href
            elif 'linkedin.com' in href and not socials['linkedin']:
                socials['linkedin'] = href
            elif ('twitter.com' in href or 'x.com' in href) and not socials['x']:
                socials['x'] = href
        
    except Exception as e:
        print(f"[Enrichment] Error extracting social links: {e}", flush=True)
    
    return socials

def find_contact_form(html: str, base_url: str) -> Optional[str]:
    """Try to find a contact form URL."""
    try:
        soup = BeautifulSoup(html, 'html.parser')
        
        for form in soup.find_all('form'):
            form_id = form.get('id', '').lower()
            form_class = ' '.join(form.get('class', [])).lower()
            
            if any(keyword in form_id or keyword in form_class 
                   for keyword in ['contact', 'צור קשר', 'יצירת קשר']):
                return base_url
        
    except Exception:
        pass
    
    return None

# ============================================================
# STEP A: PRE-LLM CONTENT GATE
# ============================================================

# Patterns to remove (navigation, footers, boilerplate)
NOISE_PATTERNS = [
    r'(?i)skip to content',
    r'(?i)cookie policy',
    r'(?i)privacy policy',
    r'(?i)terms of service',
    r'(?i)all rights reserved',
    r'(?i)© \d{4}',
    r'(?i)powered by',
    r'(?i)built with',
    r'(?i)designed by',
    r'(?i)follow us on',
    r'(?i)subscribe to our',
    r'(?i)newsletter',
    r'(?i)login|sign in|sign up',
    r'(?i)cart|checkout|add to cart',
    r'(?i)search\.\.\.?',
    r'\[.*?\]\(.*?\)',  # Markdown links
    r'#{1,6}\s*(menu|navigation|footer|header|sidebar)',
]

# Hebrew boilerplate
HEBREW_NOISE = [
    r'כל הזכויות שמורות',
    r'מדיניות פרטיות',
    r'תנאי שימוש',
    r'הרשמה לניוזלטר',
    r'עקבו אחרינו',
    r'צור קשר',  # When repeated as navigation
]

def clean_content_for_llm(markdown: str) -> str:
    """
    Light content cleaning: remove navigation, footers, repeated boilerplate.
    Returns cleaned text ready for LLM.
    """
    if not markdown:
        return ""
    
    text = markdown
    
    # Remove noise patterns
    for pattern in NOISE_PATTERNS + HEBREW_NOISE:
        text = re.sub(pattern, '', text, flags=re.IGNORECASE)
    
    # Remove excessive whitespace and empty lines
    text = re.sub(r'\n{3,}', '\n\n', text)
    text = re.sub(r' {2,}', ' ', text)
    
    # Remove very short lines (likely navigation items)
    lines = text.split('\n')
    filtered_lines = [
        line for line in lines 
        if len(line.strip()) > 15 or not line.strip()  # Keep empty or substantial lines
    ]
    text = '\n'.join(filtered_lines)
    
    return text.strip()

def count_informational_sentences(text: str) -> int:
    """
    Count unique informational sentences.
    Skip short phrases, navigation items, and repeated content.
    """
    if not text:
        return 0
    
    # Split into sentences (Hebrew and English)
    sentences = re.split(r'[.!?。]', text)
    
    # Filter for informational sentences
    seen = set()
    count = 0
    
    for sentence in sentences:
        sentence = sentence.strip()
        
        # Skip too short
        if len(sentence) < 30:
            continue
        
        # Skip if looks like navigation/slogan
        if len(sentence.split()) < 5:
            continue
        
        # Skip duplicates
        normalized = sentence.lower()[:50]
        if normalized in seen:
            continue
        seen.add(normalized)
        
        count += 1
    
    return count

def evaluate_content_quality(markdown: str) -> tuple[bool, str]:
    """
    Evaluate if content has enough signal for LLM summarization.
    
    Returns: (should_proceed, reason)
    """
    if not markdown:
        return False, "no content"
    
    cleaned = clean_content_for_llm(markdown)
    sentence_count = count_informational_sentences(cleaned)
    word_count = len(cleaned.split())
    
    # Thresholds
    MIN_SENTENCES = 5
    MIN_WORDS = 100
    
    if sentence_count < MIN_SENTENCES:
        return False, f"insufficient content ({sentence_count} sentences)"
    
    if word_count < MIN_WORDS:
        return False, f"content too thin ({word_count} words)"
    
    return True, f"ok ({sentence_count} sentences, {word_count} words)"

