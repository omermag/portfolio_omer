# ============================================================
# LAYER 1: CONTACT & SIGNALS EXTRACTION
# ============================================================

def layer_1_enrichment(scrape_result: dict) -> dict:
    """
    Layer 1: Contact & Signals Extraction (Heuristic/Regex)
    """
    full_html = scrape_result.get("full_html", "")
    full_markdown = scrape_result.get("full_markdown", "")
    homepage_url = scrape_result.get("homepage_url", "")
    
    result = {
        "emails": [],
        "primary_email": None,
        "secondary_email": None,
        "phone": None,
        "socials": {
            "instagram": None,
            "facebook": None,
            "linkedin": None,
            "x": None
        },
        "contact_form": None,
        "cleaned_content": "",
        "content_quality": (False, "")
    }
    
    # Extract emails
    all_emails = extract_all_emails(full_html, full_markdown)
    result["emails"] = all_emails
    
    primary, secondary = rank_emails(all_emails, homepage_url)
    result["primary_email"] = primary
    result["secondary_email"] = secondary
    
    # Extract phone
    result["phone"] = extract_phone_from_text(full_markdown)
    
    # Extract social links
    result["socials"] = extract_social_links(full_html)
    
    # Check for contact form
    result["contact_form"] = find_contact_form(full_html, homepage_url)
    
    # STEP A: Pre-LLM Content Gate
    cleaned = clean_content_for_llm(full_markdown)
    result["cleaned_content"] = cleaned
    result["content_quality"] = evaluate_content_quality(full_markdown)
    
    should_proceed, quality_reason = result["content_quality"]
    print(f"[L1] Emails: {len(all_emails)}, Content: {quality_reason}", flush=True)
    
    return result

# ============================================================
# LAYER 2: LLM SUMMARIZATION
# ============================================================

async def layer_2_enrichment(scrape_result: dict, business_name: str, l1_result: dict) -> dict:
    """
    Layer 2: LLM Content Summarization
    
    Single LLM call. No retries. Returns structured summary.
    """
    result = {
        "business_summary": None,
        "hooks": [],
        "founder": None
    }
    
    # Check content gate
    should_proceed, reason = l1_result.get("content_quality", (False, "unknown"))
    
    if not should_proceed:
        print(f"[L2] Skipping LLM - {reason}", flush=True)
        return result
    
    cleaned_content = l1_result.get("cleaned_content", "")
    if not cleaned_content:
        print(f"[L2] Skipping LLM - no cleaned content", flush=True)
        return result
    
    # Truncate for context window
    content = truncate_for_llm(cleaned_content, max_chars=30000)
    
    load_dotenv()
    client = openai.AsyncOpenAI(api_key=os.getenv("OPENAI_API_KEY"))
    
    try:
        response = await client.chat.completions.create(
            model="gpt-4o-mini",
            response_format={"type": "json_object"},
            messages=[
                {"role": "system", "content": SYSTEM_PROMPT},
                {"role": "user", "content": USER_PROMPT_TEMPLATE.format(
                    business_name=business_name,
                    content=content
                )}
            ]
            # Note: temperature removed - GPT-5 mini only supports default (1)
        )
        
        data = json.loads(response.choices[0].message.content)
        
        # Combine two paragraphs into single summary
        p1 = data.get("summary_p1", "").strip()
        p2 = data.get("summary_p2", "").strip()
        
        if p1 and p2:
            result["business_summary"] = f"{p1}\n\n{p2}"
        elif p1:
            result["business_summary"] = p1
        
        # Parse Hooks (Pitch Atoms)
        hooks_available = data.get("hooks_available", False)
        hooks_data = data.get("hooks", [])
        
        formatted_hooks = []
        
        if hooks_available and isinstance(hooks_data, list):
            # Clean and filter hooks
            for hook in hooks_data:
                if not isinstance(hook, str):
                    continue
                
                clean_hook = hook.strip()
                if len(clean_hook) > 10:  # Minimum length check
                    formatted_hooks.append(clean_hook)
        
        # Join into single string with DOUBLE NEWLINE for clear separation in calls/emails
        result["hooks"] = "\n\n".join(formatted_hooks) if formatted_hooks else None
        result["founder"] = data.get("founder")
        
        summary_len = len(result["business_summary"]) if result["business_summary"] else 0
        print(f"[L2] Summary: {summary_len} chars, Hooks: {len(formatted_hooks)}", flush=True)
        
    except Exception as e:
        print(f"[L2] LLM Error: {e}", flush=True)
    
    finally:
        # CRITICAL: Close the async client to prevent resource leaks
        await client.close()
    
    return result

# ============================================================
# MAIN ENRICHMENT FUNCTION
# ============================================================

async def enrich_lead(scrape_result: dict, business_name: str, skip_llm: bool = False) -> dict:
    """
    Complete enrichment pipeline: Layer 1 + Layer 2
    """
    # Layer 1: Extract contacts and signals
    l1 = layer_1_enrichment(scrape_result)
    
    # Layer 2: LLM content understanding
    if not skip_llm:
        l2 = await layer_2_enrichment(scrape_result, business_name, l1)
    else:
        l2 = {
            "business_summary": "[SKIPPED] Test mode",
            "hooks": [],
            "founder": None
        }
    
    # Combine
    enriched = {
        "email": l1["primary_email"],
        "secondary_email": l1["secondary_email"],
        "phone": l1["phone"],
        "instagram": l1["socials"]["instagram"],
        "facebook": l1["socials"]["facebook"],
        "linkedin": l1["socials"]["linkedin"],
        "x": l1["socials"]["x"],
        "additional_contact_form": l1["contact_form"],
        "business_summary": l2["business_summary"],
        "hooks": l2["hooks"],  # Already formatted as string in layer_2_enrichment
        "founder": l2["founder"]
    }
    
    return enriched
