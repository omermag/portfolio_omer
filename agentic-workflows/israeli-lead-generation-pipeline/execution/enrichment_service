import httpx
import html2text
import asyncio
from typing import Optional, List, Tuple
from urllib.parse import urljoin, urlparse
from bs4 import BeautifulSoup

# Configure html2text
h = html2text.HTML2Text()
h.ignore_links = False
h.ignore_images = True
h.ignore_emphasis = False
h.body_width = 0

HEADERS = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
}

TIMEOUT = httpx.Timeout(15.0, connect=10.0)

# Retry configuration
MAX_RETRIES = 3
RETRY_DELAY = 2.0  # seconds

# Keywords for finding relevant subpages (Hebrew + English)
SUBPAGE_KEYWORDS = [
    'contact', 'about', 'team', 'staff', 'people', 'service', 'support', 'info', 'career',
    'צור קשר', 'יצירת קשר', 'אודות', 'צוות', 'אנשים', 'שירות', 'תמיכה', 'מידע', 'דרושים', 'קריירה',
    'קצת עלינו', 'עלינו', 'אודותינו', 'פניות'
]

async def fetch_page(client: httpx.AsyncClient, url: str, retries: int = MAX_RETRIES) -> Tuple[Optional[str], Optional[str]]:
    """
    Fetch a single page with smart retry logic.
    Only retries on transient errors (timeout, connection).
    Skips retry on permanent errors (404, 403, etc).
    Returns: (html_content, markdown_content)
    """
    # Errors worth retrying (transient)
    RETRYABLE_ERRORS = (
        httpx.TimeoutException,
        httpx.ConnectError,
        httpx.ReadError,
        httpx.WriteError,
        ConnectionResetError,
    )
    
    last_error = None
    
    for attempt in range(retries):
        try:
            response = await client.get(url, headers=HEADERS, follow_redirects=True)
            response.raise_for_status()
            
            html = response.text
            markdown = h.handle(html)
            
            return html, markdown
            
        except httpx.HTTPStatusError as e:
            # Permanent HTTP errors - don't retry
            status = e.response.status_code
            if status in (404, 403, 401, 410):  # Not found, Forbidden, Unauthorized, Gone
                print(f"[Scraper] Permanent error {status} for {url} - skipping retries", flush=True)
                return None, None
            # 5xx errors might be transient, retry those
            last_error = e
            
        except RETRYABLE_ERRORS as e:
            # Transient errors - retry
            last_error = e
            
        except Exception as e:
            # Unknown error - don't retry
            print(f"[Scraper] Unexpected error for {url}: {type(e).__name__} - {e}", flush=True)
            return None, None
        
        # Retry logic for transient errors
        if attempt < retries - 1:
            wait_time = RETRY_DELAY * (attempt + 1)
            print(f"[Scraper] Retry {attempt + 1}/{retries} for {url} in {wait_time}s...", flush=True)
            await asyncio.sleep(wait_time)
        else:
            print(f"[Scraper] Failed to fetch {url} after {retries} attempts: {type(last_error).__name__}", flush=True)
    
    return None, None

def extract_internal_links(html: str, base_url: str, max_links: int = 5) -> List[str]:
    """
    Parse HTML and extract internal links with smart prioritization.
    
    Strategy:
    1. Extract ALL internal links (same domain)
    2. Prioritize by relevance (about, services, contact, etc.)
    3. Return top max_links prioritized links
    
    This ensures maximum content extraction for LLM analysis.
    """
    try:
        soup = BeautifulSoup(html, 'html.parser')
        base_domain = urlparse(base_url).netloc
        
        # Priority keywords for ranking
        HIGH_PRIORITY = ['about', 'אודות', 'עלינו', 'services', 'שירותים', 'team', 'צוות']
        MED_PRIORITY = ['contact', 'צור קשר', 'portfolio', 'projects', 'פרויקטים', 'clients', 'לקוחות']
        
        links_with_priority = []
        
        for a_tag in soup.find_all('a', href=True):
            href = a_tag['href']
            link_text = a_tag.get_text(strip=True).lower()
            
            # Build absolute URL
            full_url = urljoin(base_url, href)
            parsed = urlparse(full_url)
            
            # Only internal links (same domain)
            if parsed.netloc != base_domain:
                continue
            
            # Clean URL (remove fragments)
            clean_url = f"{parsed.scheme}://{parsed.netloc}{parsed.path}"
            
            # Don't add homepage again
            if clean_url == base_url or clean_url == base_url + '/':
                continue
            
            # Calculate priority score
            priority = 3  # Default: low priority
            combined_text = (link_text + ' ' + href.lower())
            
            if any(keyword in combined_text for keyword in HIGH_PRIORITY):
                priority = 1  # High priority
            elif any(keyword in combined_text for keyword in MED_PRIORITY):
                priority = 2  # Medium priority
            
            links_with_priority.append((clean_url, priority))
        
        # Remove duplicates while preserving priority
        unique_links = {}
        for url, priority in links_with_priority:
            if url not in unique_links or priority < unique_links[url]:
                unique_links[url] = priority
        
        # Sort by priority (lower number = higher priority)
        sorted_links = sorted(unique_links.items(), key=lambda x: x[1])
        
        # Return top max_links
        result = [url for url, _ in sorted_links[:max_links]]
        
        print(f"[Scraper] Found {len(unique_links)} unique internal links, selected top {len(result)}", flush=True)
        
        return result
    
    except Exception as e:
        print(f"[Scraper] Error parsing links: {e}", flush=True)
        return []

async def scrape_website_multi_page(url: str, max_pages: int = 5) -> dict:
    """
    Scrape website: homepage + up to max_pages internal pages.
    
    Returns:
    {
        "homepage_url": str,
        "homepage_html": str,
        "homepage_markdown": str,
        "subpages": [
            {"url": str, "html": str, "markdown": str},
            ...
        ],
        "full_markdown": str,  # Concatenated markdown from all pages
        "full_html": str,      # Concatenated HTML from all pages
        "success": bool
    }
    """
    result = {
        "homepage_url": url,
        "homepage_html": "",
        "homepage_markdown": "",
        "subpages": [],
        "full_markdown": "",
        "full_html": "",
        "success": False
    }
    
    try:
        async with httpx.AsyncClient(timeout=TIMEOUT, verify=False) as client:
            # 1. Fetch homepage
            home_html, home_markdown = await fetch_page(client, url)
            
            if not home_html:
                print(f"[Scraper] Failed to fetch homepage: {url}", flush=True)
                return result
            
            result["homepage_html"] = home_html
            result["homepage_markdown"] = home_markdown
            result["full_html"] = home_html
            result["full_markdown"] = f"# HOMEPAGE: {url}\n\n{home_markdown}\n\n"
            
            # 2. Extract internal links
            internal_links = extract_internal_links(home_html, url, max_links=max_pages)
            
            if not internal_links:
                print(f"[Scraper] No internal links found for {url}", flush=True)
                result["success"] = True
                return result
            
            print(f"[Scraper] Found {len(internal_links)} relevant subpages for {url}", flush=True)
            
            # 3. Fetch subpages in parallel
            tasks = [fetch_page(client, link) for link in internal_links]
            subpage_results = await asyncio.gather(*tasks)
            
            # 4. Compile results
            for link, (sub_html, sub_markdown) in zip(internal_links, subpage_results):
                if sub_html and sub_markdown:
                    result["subpages"].append({
                        "url": link,
                        "html": sub_html,
                        "markdown": sub_markdown
                    })
                    result["full_html"] += f"\n\n<!-- SUBPAGE: {link} -->\n\n{sub_html}"
                    result["full_markdown"] += f"# SUBPAGE: {link}\n\n{sub_markdown}\n\n"
            
            result["success"] = True
            print(f"[Scraper] Successfully scraped {url}: 1 homepage + {len(result['subpages'])} subpages", flush=True)
            
    except Exception as e:
        print(f"[Scraper] Error scraping {url}: {e}", flush=True)
    
    return result

