def extract_phone_from_text(text: str) -> Optional[str]:
    """Extract Israeli phone number from text."""
    if not text:
        return None
    
    patterns = [
        r'0[0-9]{1,2}[-\s]?[0-9]{7}',
        r'\+972[-\s]?[0-9]{1,2}[-\s]?[0-9]{7}',
    ]
    
    for pattern in patterns:
        match = re.search(pattern, text)
        if match:
            phone = match.group(0)
            phone = re.sub(r'[-\s]', '', phone)
            return phone
    
    return None

def is_valid_website(url: str) -> bool:
    """Basic validation for website URL."""
    if not url:
        return False
    
    url_lower = url.lower()
    
    if not (url_lower.startswith('http://') or url_lower.startswith('https://')):
        return False
    
    excluded = ['facebook.com', 'linkedin.com', 'instagram.com', 'twitter.com']
    if any(exc in url_lower for exc in excluded):
        return False
    
    return True

def truncate_for_llm(text: str, max_chars: int = 40000) -> str:
    """Truncate text to fit LLM context window."""
    if len(text) <= max_chars:
        return text
    return text[:max_chars] + "\n\n[...truncated]"
