import hashlib
import re
from typing import Optional, List, Tuple
from urllib.parse import urlparse

def generate_lead_id(business_name: str, city: str) -> str:
    """Generate unique lead ID from business name and city."""
    name = (business_name or "unknown").lower().strip()
    loc = (city or "unknown").lower().strip()
    raw = f"{name}|{loc}"
    return hashlib.md5(raw.encode('utf-8')).hexdigest()[:16]

def clean_text(text: str) -> str:
    """Remove excessive whitespace and normalize text."""
    if not text:
        return ""
    text = re.sub(r'\s+', ' ', text)
    return text.strip()

